# Public bind for this project container only (avoid port conflicts with other projects)
APP_BIND_IP=127.0.0.1
APP_PORT=18080

# Optional: automatic HTTPS via host nginx + Let's Encrypt.
# If DOMAIN and LETSENCRYPT_EMAIL are set, install.sh configures nginx
# reverse proxy and obtains certificate via certbot.
DOMAIN=
LETSENCRYPT_EMAIL=

# Django
DJANGO_DEBUG=0
DJANGO_SECRET_KEY=change-me-to-a-long-random-secret
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com
CSRF_TRUSTED_ORIGINS=https://your-domain.com
CORS_ALLOWED_ORIGINS=https://your-domain.com
SESSION_COOKIE_SECURE=1
CSRF_COOKIE_SECURE=1
SECURE_SSL_REDIRECT=0
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=1
SECURE_HSTS_PRELOAD=1

# DB (sqlite | postgresql | mysql)
DB_ENGINE=sqlite
DB_NAME=pet
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=postgres
DB_PORT=5432

# Gunicorn
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=60
AUTO_SEED_EXAMS=0
AUTO_SEED_EXAMS_FORCE=0

# Static files / WhiteNoise safety toggles
DJANGO_COLLECTSTATIC=1
COLLECTSTATIC_STRICT=0
STATICFILES_USE_MANIFEST=0
WHITENOISE_MANIFEST_STRICT=0
